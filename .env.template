# Video Distribution Portal Configuration

## Database Settings (MariaDB)
# Format: mysql+pymysql://user:password@hostname:port/database_name
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/video_portal
# Set to 1 to disable SSL (equivalent to --ssl=0 in some clients)
DB_SSL_DISABLED=0

## Security Settings
# Generate a secret key: openssl rand -hex 32
SECRET_KEY=replace_with_a_secure_random_string
PORT=8082
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

## Filesystem Settings
# Base directory where user projects are stored
BASE_VIDEO_DIR=/tmp/videos

## Timelapse Rendering (Script)
# Directory where image folders are located (e.g. /home/user/images)
TIMELAPSE_IMAGES_DIR=/home/sector7gp/tony_timelapse/images
# Directory where generated videos will be saved
TIMELAPSE_VIDEOS_DIR=/home/sector7gp/tony_timelapse/videos
# Remote destination for rsync (e.g. user@ip:/path)
REMOTE_SYNC_DEST=sector7gp@192.168.1.100:/tmp/videos/Riva
